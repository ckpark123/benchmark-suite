{
  "name": "@benchlytix/benchmark-suite",
  "version": "0.1.0-rc.1",
  "description": "Independent benchmark test suite for AI agents — used by BenchLytix.com",
  "license": "Apache-2.0",
  "author": "BenchLytix <hello@benchlytix.com>",
  "homepage": "https://github.com/ckpark123/benchmark-suite",
  "repository": {
    "type": "git",
    "url": "https://github.com/ckpark123/benchmark-suite.git"
  },
  "bugs": {
    "url": "https://github.com/ckpark123/benchmark-suite/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "benchlytix-benchmark": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist/",
    "cases/",
    "rubrics/",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "lint": "eslint 'src/**/*.ts' '__tests__/**/*.ts'",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate-cases": "tsx scripts/validate-cases.ts",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "chalk": "5.3.0",
    "commander": "12.1.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.12.7",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "express": "4.19.2",
    "tsx": "4.19.0",
    "typescript": "5.4.5",
    "vitest": "1.6.0"
  },
  "keywords": [
    "ai",
    "agent",
    "benchmark",
    "evaluation",
    "llm",
    "benchlytix"
  ]
}
